# ── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/marcenaria_app
MONGODB_TEST_URI=mongodb://localhost:27017/marcenaria_test

# ── JWT (gere novos para produção: openssl rand -base64 64) ─
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (origens permitidas, separadas por vírgula) ─────
# Inclua admin, landing e localhost de dev
FRONTEND_URL=https://admin.conectamarceneiro.com.br,https://conectamarceneiro.com.br

# ── App / E-mail (Resend) ─────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
APP_URL=https://conectamarceneiro.com.br

# ── AWS S3 (upload de imagens) ────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Asaas (PRODUÇÃO) ──────────────────────────────────────
ASAAS_API_KEY=
ASAAS_API_URL=https://www.asaas.com/api/v3
ASAAS_WALLET_ID=
ASAAS_WEBHOOK_SECRET=
WEBHOOK_SECRET=

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# ── Upload ────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
